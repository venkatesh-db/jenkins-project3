

pipeline {

    agent any 

    stages {

        stage('Clone Code'){

            steps {
                git 'https://github.com/your-repo/your-project.git'
            }
        }

        stage('Build'){

            steps {

                sh 'docker build -t your-image-name .'
            }
        }

        stage('Run'){

            steps {
                sh 'docker run -d -p 8080:8080 your-image-name'
            }

        }

    }

}